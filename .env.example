# ─── GitHub source (required) ───────────────────────────────────────────────
# Personal Access Token (classic or fine-grained) or GitHub App token with
# READ access to the target repository's contents.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Repository to mirror, in "owner/name" form.
GITHUB_REPO=my-org/my-private-repo

# Branch to read from. Defaults to "main".
GITHUB_BRANCH=main

# Optional sub-directory inside the repo to treat as the viewer root.
# Leave empty to expose the whole repository.
GITHUB_BASE_PATH=

# ─── Access control (optional but recommended for private content) ──────────
# When BOTH are set, every page is protected by HTTP Basic Auth.
# Leave empty if you front the app with SSO (Cloudflare Access, oauth2-proxy, …).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# ─── Branding / behaviour (optional) ────────────────────────────────────────
# Title shown in the header and browser tab.
APP_TITLE=Polyview

# Seconds to cache GitHub API responses in memory. Defaults to 60.
CACHE_TTL=60

# Max file size (bytes) the viewer will fetch and render. Defaults to 2 MB.
MAX_FILE_BYTES=2097152
